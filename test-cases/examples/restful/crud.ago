interface DbField{
// DbField need support composeTypeName, however it can't constraint on metaclass
// and for standard data types, it will translate to each database typename with its adapter
// only db owned types need implement this interface, i.e. JSONB in PG
//    metaclass{
//        fun composeTypeName() as string {
//        }
//    }
}


class VarChar from String{
    metaclass{
        maxLength as int
        fun new(maxLength as int){
            this.maxLength = maxLength
        }
    }
}

class BigInt from Boxer<long>{
    override toString() as string{
        return "" + this.value
    }
}

native class QueryResultIterator<T> with Iterator<T>{
    override hasNext() as boolean native "org.siphonlab.ago.runtime.rdb.QueryResult.hasNext"
    override next() as T native "org.siphonlab.ago.runtime.rdb.QueryResult.next"
}

// everything stored in db, but only extends Table can have getRowById and table functions
// and if GC enabled, if not extends Table the data will be clean by GC
class Entity<T, Id as [Primitive]> from QueryResult{
    get id() as Id native "org.siphonlab.ago.runtime.db.sdk.Entity.getId";

    metaclass{
        fun of(id as Id) as T native "org.siphonlab.ago.runtime.db.sdk.Entity.getEntityById";

        fun fetchAll() as QueryResultIterator<T> native "org.siphonlab.ago.runtime.db.sdk.Entity.fetchAll"
    }
}

// query result, sql result of SELECT and other CTE output QueryResultIterator<QueryResult> if not return Entity
// that means query result are: QueryResultIterator<special Entity>, QueryResultIterator<special QueryResult>, and int (for update/delete count)
// for SELECT and CTE, the result is typed QueryResult, i.e. for query `SELECT name FROM User`, the query result is: `class QueryFunctionNameResult{final name as User.Name}`
// if the query works on *, the result is the Entity
class QueryResult{

}

class User from Entity<User, long> {
    metaclass{
        class Name from VarChar::(100)
        class Address from VarChar::(200)
        class Age from BigInt
    }
    name as Name;
    address as Address;
    age as Age
}

fun createUser() as User {
    var u = new User() with {
        .name = "Tom";
        .address = "liberation street 222";
        .age = 20;
    }
    return u;
}

fun getUser(id as long) as User{
    var u = User.of(id)
    return u;
}

fun main(){
    var u = await createUser() via EntitySpace.new#();

    Trace.print(u.name)
    Trace.print(u.age)

    // next time we can load from existed data
    var u2 = await getUser(u.id) via EntitySpace.new#();
    Trace.print(u2.name)
    Trace.print(u2.age)
}


class Query<+R> from Function<R>{
    metaclass{
        protected dialects as Map<string, string?> = new HashMap<string, string?>();
    }
}

fun executeQuery<R>(sql as string, args as Object?) as QueryResultIterator<R> native "org.siphonlab.ago.runtime.db.sdk.Entity.executeQuery";

// to fork entity runspace
native class EntitySpace with ForkContext{
    fun new#() native "org.siphonlab.ago.runtime.db.sdk.ForkEntityRunSpace.create";
}

// to fork workflow runspace
native class WorkflowSpace with ForkContext{
    fun new#() native "org.siphonlab.ago.runtime.db.sdk.ForkWorkflowRunSpace.create";
}

// to fork entity workflow runspace
native class EntityWorkflowSpace with ForkContext{
    fun new#() native "org.siphonlab.ago.runtime.db.sdk.ForkEntityWorkflowRunSpace.create";
}

