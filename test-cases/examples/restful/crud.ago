    var addr3_1 = {Address | user: u3, street: "No.45 Nanshan Rd.", city: "Shenzhen", state: "Guangdong", zipCode: "518000", country: 'China', isPrimary: true}
    var addr3_2 = {Address | user: u3, street: "No.7 Tianhe Ave.", city: "Shenzhen", state: "Guangdong", zipCode: "518001", country: 'China', isPrimary: false}

    // 4. Carol
    var u4 = {User | name: "Carol", phone: "13765432109", age: 22}
    var addr4_1 = {Address | user: u4, street: "No.12 Huadu Rd.", city: "Guangzhou", state: "Guangdong", zipCode: "510300", country: 'China', isPrimary: true}

    // 5. David
    var u5 = {User | name: "David", phone: "13654321098", age: 30}
    var addr5_1 = {Address | user: u5, street: "No.8 Haizhu Rd.", city: "Guangzhou", state: "Guangdong", zipCode: "510400", country: 'China', isPrimary: true}
    var addr5_2 = {Address | user: u5, street: "No.15 Tianhe Ave.", city: "Shenzhen", state: "Guangdong", zipCode: "518001", country: 'China', isPrimary: false}

