query UserByName(name as string?) {
    sql{.
        SELECT
            u.id          AS userId,
            u.name        AS userName,
            a.street      AS street,
            a.city        AS city,
            a.state       AS state,
            a.zipCode     AS zip,
            a.country     AS country
        FROM
            User u
        JOIN
            Address a
        ON
            a.user = u.id
        WHERE
            a.isPrimary = true
    .}
}

query UserByName2(name as string?) {
    sql{.
        SELECT
            u.id          AS userId,
            u.name        AS userName,
            a.street      AS street,
            a.city        AS city,
            a.state       AS state,
            a.zipCode     AS zip,
            a.country     AS country
        FROM
            User u, Address a
        WHERE
            a.user = u.id
            AND a.isPrimary = true
    .}
}

class Address from Entity<Address, long> {
    user as User;

    street      as string;
    city        as string;
    state       as string;
    zipCode     as string;
    country     as string;

    isPrimary   as boolean;
}

