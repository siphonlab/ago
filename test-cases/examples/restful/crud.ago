class VarChar from String{
    metaclass{
        maxLength as int
        fun new(maxLength as int){
            this.maxLength = maxLength
        }
    }
}

class BigInt from Boxer<long>{
    override toString() as string{
        return "" + this.value
    }
}


class User from Entity<User, long> {
    metaclass{
        class Name from VarChar::(100)
        class Phone from VarChar::(200)
        class Age from BigInt
    }
    public name as Name;
    public phone as Phone;
    public age as Age
}

fun initData(){
    // 1. Tom
    var u1 = {User | name: "Tom", phone: "13344456666", age: 20}
    var addr1_1 = {Address | user: u1, street: "No.10 Wenchang Rd.", city: "Guangzhou", state: "Guangdong", zipCode: "510000", country: 'China', isPrimary: true}
