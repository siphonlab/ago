query userByName(name as string?, minAge as int?, maxAge as int?, sort as Sort[]? = [Sort[] | new Sort('u.name', 'asc')]) {
    sql{.
        SELECT u.id, u.name, u.age FROM User u WHERE name = :name AND age >= :minAge AND age <= :maxAge
        ORDER BY :sort ASC
    .}
}

query join_test(name as string?) {
    sql{.
        SELECT
            u.name        AS userName,
            a.street      AS street,
            a.city        AS city,
            a.state       AS state,
            a.zipCode     AS zip,
            a.country     AS country
        FROM
            User u
        JOIN
            Address a
        ON
            a.user = u.id
        WHERE
            a.isPrimary = true AND u.name = :name
    .}
}
