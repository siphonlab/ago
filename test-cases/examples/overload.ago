public class ClassTest {
    class Animal{
        name = "Animal";
    }
    class Dog from Animal{
        fun new(){this.name = "Dog";}
    }

    class Samoyed from Dog{
        fun new(){this.name = "Samoyed";}
    }

    class A{
        fun handle(f as Animal, d as Dog){
            print("you are animal");
        }
        fun handle(f as Dog, a as Animal){
            print("you are dog");
        }
        fun handle(f as Samoyed, a as Animal){
            print("you are samoyed");
        }
        fun handle(f as Animal){
            print("you are animal");
        }
        fun handle(f as Dog){
            print("you are dog");
        }
        fun handle(f as Samoyed){
            print("you are samoyed");
        }
        fun handle(f as Object){

        }
    }

    public static fun main(args as String[]) {
        var d = new Samoyed();
        new A().handle(d);      //
        new A().handle(d as Animal);
        new A().handle(d, d as Animal);
        // new A().handle(d, d);       // Ambiguous method call. ClassTest.A 中的方法 handle(ClassTest.Animal,ClassTest.Dog) 和 ClassTest.A 中的方法 handle(ClassTest.Samoyed,ClassTest.Animal) 都匹配
    }
}
