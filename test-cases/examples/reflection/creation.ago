class Staff{
    public name as string;
    age as int {public get; public set;}

    fun work(title as string, duration as int){
        Trace.print($"name: ${name} do ${title}, already ${duration} min"$)
    }
}

class A{
    private text as string = "I am A"

    class B{
        fun test(){
            Trace.print(text);
        }
    }

    class C{
        fun new(field foo as string){ }
        fun test(){
            Trace.print(text + foo)
        }
    }
}

fun main(){
    var staff = new Staff() with {.name = 'Tom'; .age = 20};

    var staff2 = Staff.createInstance() | Staff;
    staff2.name = "Jack"
    staff2.age = 22;

    Trace.print(staff2.name)
    Trace.print(staff2.age)

//    var a = new A();
//    var b = A.getChild('B').createInstance(a);
//    b.invoke('test');
}