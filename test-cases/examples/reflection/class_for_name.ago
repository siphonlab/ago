class Staff{
    public name as string;
    age as int {public get; public set;}

    fun work(title as string, duration as int){
        Trace.print($"name: ${name} do ${title}, already ${duration} min"$)
    }
}

class A{
    private text as string = "I am A"

    public class B{
        fun test(){
            Trace.print(text);
        }
    }

    public class C{
        f as string
        fun new#1(field foo as string){ }
        fun new#2(foo as string, f as string){
            this.f = f;
            this.foo = foo + f;
        }
        fun test(){
            Trace.print(text + foo)
        }
    }
}

fun main(){
    var staffClass = Class.forName('Staff');

    var staff2 = staffClass!.createInstance() | Staff;
    staff2.name = "Jack"
    staff2.age = 22;

    Trace.print(staff2.name)
    Trace.print(staff2.age)
}