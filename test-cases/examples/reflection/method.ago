class Animal{
    metaclass{
        fun foo(){
            Trace.print("Animal.foo")
        }
    }
    fun bark(){
    }
}
class Cat from Animal{
    metaclass{
        override foo(){
            Trace.print("Cat.foo")
        }
    }
    override bark(){
        Trace.print("meow")
    }
}
class Dog from Animal{
    override bark(){
        Trace.print("woof")
    }
}

class Calc{
    fun add(a as int, b as int) as int{
        return a + b
    }
    fun subtract(a as int, b as int) as int{
        return a - b
    }
}

class Staff{
    public name as string;
    age as int {public get; public set;}

    fun work(title as string, duration as int){
        Trace.print($"name: ${name} do ${title}, already ${duration} min"$)
    }
}

fun main(){
    var calc = new Calc();
    var method = Calc.class.getMethod('add#');
    Trace.print(method);        // class add#
    var r = calc.invoke(method!, 1, 2);
    Trace.print(r);

    var b = calc.invoke('subtract#', 8, 4)
    Trace.print(b);
}