class Staff{
    name as string;
    override hashCode() as int{
        return name|Object .hashCode()
    }
    fun new(name as string){
        this.name = name;
    }
}

fun main(){
    var m = new HashMap<int, string>();
    m.put(1, 'John')
    m.put(100, 'Jack')
    Trace.print(m.get(100))

    m[2] = "Sally"
    m[3] = m[2] + ',' + m[1]
    Trace.print(m[3])

    for(var entry in m){
        Trace.print(entry.key + " = " + entry.value)
    }

    for(var key in m.keys){
        Trace.print(key);
    }

    for(var value in m.values){
        Trace.print(value);
    }

    var scores = new HashMap<Staff, int>();
    var tom = new Staff('Tom');
    var mike = new Staff('Mike');
    scores[tom] = 80
    scores[mike] = 90
    Trace.print(scores[tom])
}