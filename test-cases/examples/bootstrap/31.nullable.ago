class Animal{
    public name as string;
    fun bark(){
    }

    fun getName() as string{
        return name;
    }
}
class Cat from Animal{
    fun new(){
        this.name = 'Tom'
    }
    override bark(){
        Trace.print("meow")
    }
}
class Dog from Animal{
    fun new(){
        this.name = 'Jerry'
    }
    override bark(){
        Trace.print("woof")
    }
}

class Samoyed from Dog{
    fun new(){
        this.name = 'Snow'
    }
    override bark(){
        Trace.print("Samoyed")
    }
}

fun main(){
    var i as int? = 2026
    var j = i!
    Trace.print(j)

    i = null;
    try{
        j = i!;
    } catch(ex as lang.ClassCastException){
        Trace.print(ex.message)     // can't cast null to 'int'
    }

    foo(null);
    foo(new Dog())
}

fun foo(animal as Animal?){
    var fld = animal?.name;
    if(fld != null){
        Trace.print(fld!);
