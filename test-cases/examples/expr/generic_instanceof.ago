fun f<T>(t as T){
    if(t instanceof int i){             // impossible to implement `if(t instanceof Primitive p) ...`
        g(i)
    } else if(t instanceof string s){
        g(s)
    } else {
        Trace.print("non primitive type")
        g(t)
    }
    if(t instanceof Object obj){
        g(obj)
    }
}

fun g(obj as Object){
    Trace.print(obj);
}

fun main(){
    var i = 20

    f(i)

    //f(fun.this)    main#@5c0d2070
}