class Person{
    public name as string;
    gender as char {get; set;}

    override toString() as string{
        return $"name: ${name}  gender: ${gender}"$
    }
}

class Staff from Person{
    public workNo as string;
    public salary as int
    override toString() as string{
        return $"name: ${name}  gender: ${gender}  workNo: ${workNo} salary: ${salary}"$
    }
}

fun main(){
    var tom = {Person| name: "Tom", gender: 'M'}
    Trace.print(tom)

    var staff = {Staff| ...tom, workNo: '1001', salary: 10200}
    Trace.print(staff)

    var map = {HashMap<string, Object> | workNo: '1003', salary: 13332};

    var mike as Staff = {...staff, name: 'Mike', ... map}
    Trace.print(mike)
}