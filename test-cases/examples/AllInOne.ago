class PatternMatching4switchExp {

    fun f(i as int) {
    }

    fun f1(obj as Object) {
        switch (obj) {
            case null -> f(0);
            case s as String -> f(1);
            case a as int[] -> f(2);
            default -> f(-1);
        }
    }

    fun f2(obj as Object) {
        switch (obj) {
            case null -> f(0);
            case l as Long -> f(1);
            case i as Integer -> f(1);
            case a as int[] -> f(2);
            default -> f(-1);
        }
    }

    fun f3(o as Object) {
        switch (o) {
            case null ->
            case l as Long ->
                f(0);
                break;
            default ->
                break;
        }
    }

    enum E1 {
        var;
    }

    fun f4() {
        var var = E1.var;
        switch (var) {
            case var ->
                return;
            default ->
                break;
        }

        switch (var) {
            case var -> {
            }
            default -> {
            }
        }
    }

    fun f5(n as Number) as int{
        return switch (n) {
            case l as Long and l.intValue() == 1 and l.byteValue() == 1 -> l.byteValue();
            case Var as Long -> Var.byteValue();
            case i as Integer -> i.byteValue();
            default -> throw new RuntimeException("");
        };
    }

    fun f6(obj as Object) as Function<Integer, String>{
        var b as boolean = true;
        return switch (obj) {
            case var as String and b -> t -> var;
            default -> t -> "Default string";
        };
    }

    fun dummy() as int {
        return 0;
    }

    fun f7(obj as Object) as Function<Integer, String>{
        var b as boolean = true;
        var b2 = true;
        var b3 = true;
        return switch (obj) {
            case s as string and (b and b2) and s.length() > 0 and dummy() == 1 -> t => s;
            case i as Integer and b and b2 and (b and b2) and b3 and (b and b2) -> t => "";
            case i as Integer and b and b2 and (b and b2) and b3 and (b and b2 and not b3) -> {
                yield t => "";
            }
            case final l as  Long and (b2 if b else b3) -> {
                yield t => "";
            }
            default -> t => "Default string";
        };
    }

    fun f8(o as Object, i as int) {
        switch (i) {
            case 1, 2 ->
            case 3, 4 -> {
            }
        }

        switch (o) {
            case b as Number -> {
            }
            default -> {
            }
        }

        var f = switch (o) {
            case final l as I2 -> {
                yield switch (o) {
                    case b a Byte  -> 1;
                    default -> 0;
                };
            }
            default -> {
                yield 1;
            }
        };
    }
}

