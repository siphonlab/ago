fun main(){
    testIfElse();
}

fun testIfElse(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;

    Trace.print("yes" if b else "no");      // yes
    Trace.print("yes" if b2 else "no");     // no
    Trace.print("yes" if b3 else "no");     // no

    Trace.print("no" if not b else "yes");      // yes
    Trace.print("no" if not b2 else "yes");     // no
    Trace.print("no" if not b3 else "yes");     // no

    var i as int? = 2026;
    var n as int? = null;

    Trace.print("hello " + (i + 1) if i else "no");      // yes
    Trace.print("hello " + (n + 1) if n else "no");      // no
    Trace.print("no" if not i else "hello " + (i + 1));      // yes
    Trace.print("no" if not n else "hello " + (n + 1));      // no
}