fun main(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;

    Trace.print(b == true)          // true
    Trace.print(b2 == false)        // true
    Trace.print(b3 == false)        // false
    Trace.print(b3 == null)         // true

    var i as int? = 200;
    var n as int? = null;

    Trace.print(i == 200)       // true
    Trace.print(n == 200)       // false
    Trace.print(n != 200)       // false
    Trace.print(n == null)      // true

    var j as int? = 200;
    var k as int? = 100;

    Trace.print(i == j);        // true
    Trace.print(i != j);        // false
    Trace.print(i == k);        // false
    Trace.print(i != k);        // true
}