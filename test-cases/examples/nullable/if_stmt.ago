fun main(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;

    var i as int? = 200;
    var n as int? = null;

    if(b){
        Trace.print("b yes");
    } else {
        Trace.print("b no");
    }

    if(b2){
        Trace.print("b2 yes");
    } else {
        Trace.print("b2 no");
    }

    if(b3){
        Trace.print("b3 yes");
    } else {
        Trace.print("b3 no");
    }

    if(i){
        Trace.print("i yes");
    } else {
        Trace.print("i no");
    }

    if(n){
        Trace.print("n yes");
    } else {
        Trace.print("n no");
    }

    if(not b){
        Trace.print("b no");
    } else {
        Trace.print("b yes");
    }

    if(not b2){
        Trace.print("b2 no");
    } else {
        Trace.print("b2 yes");
    }

    if(not b3){
        Trace.print("b3 no");
    } else {
        Trace.print("b3 yes");
    }

    if(not i){
        Trace.print("i no");
    } else {
        Trace.print("i yes");
    }

    if(not n){
        Trace.print("n no");
    } else {
        Trace.print("n yes");
    }
}