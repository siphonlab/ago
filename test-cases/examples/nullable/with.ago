class Person{
    fun new(field name as string, field age as int){}
}

fun main(){
    var p as Person? = new Person('Unknown', 0);
    var p2 as Person? = null;

    var p3 = p with {.name = 'John'; .age = 20;};
    var p4 = p2 with {.name = 'John'; .age = 20};

    with (p3){
        Trace.print(.name);
        Trace.print(.age);
    }

    with (p4){
        Trace.print(.name);
        Trace.print(.age);
    }
}