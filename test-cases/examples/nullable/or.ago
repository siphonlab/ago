fun main(){
    testOr();
}

fun testOr(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;
    Trace.print(b or b2)        // true
    Trace.print(b3 or b)        // true
    Trace.print(b2 or b)        // true
    Trace.print(b3 or b3)       // false

    Trace.print(b or false)     // true
    Trace.print(false or b)     // true
    Trace.print(b2 or false)    // false
    Trace.print(false or b2)    // false
    Trace.print(b3 or false)    // false
    Trace.print(false or b3)    // false

    var i as int? = 200;
    var n as int? = null;

    Trace.print(i or n)         // 200
    Trace.print(i or i)         // 200
    Trace.print(true or i)      // true
    Trace.print(n or i)         // 200
    Trace.print(n or n)         // null
}
