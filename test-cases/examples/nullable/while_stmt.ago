fun main(){
    testWhile();
    testDoWhile();
}

fun testWhile(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;

    var i as int? = 5;
    var n as int? = null;

    while(b){
        Trace.print('b yes');
        break;
    }

    while(b2){
        Trace.print('b2 yes');
        break;
    }

    while(b3){
        Trace.print('b3 yes');
        break;
    }

    while(not b){
        Trace.print('b no');
        break;
    }

    while(not b2){
        Trace.print('b2 no');
        break;
    }

    while(not b3){
        Trace.print('b3 no');
        break;
    }

    while(i){
        Trace.print(i);
        i = i! - 1;
    }

    i = 5;
    while(i){
        Trace.print(i);
        i = null;
    }
}

fun testDoWhile(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;

    var i as int? = 5;
    var n as int? = null;

    var k = 0;
    do{
        Trace.print('b loop');
        if(++k == 2) break
    } while(b);

    k = 0;
    do{
        Trace.print('b2 loop');
        if(++k == 2) break
    }while(b2);

    k = 0;
    do{
        Trace.print('b3 loop');
        if(++k == 2) break
    }while(b3);

    k = 0;
    do{
        Trace.print('b not loop');
        if(++k == 2) break
    } while(not b);

    k = 0;
    do{
        Trace.print('b2 not loop');
        if(++k == 2) break
    } while(not b2);

    k = 0;
    do{
        Trace.print('b3 not loop');
        if(++k == 2) break
    }while(not b3);

    do{
        Trace.print(i);
        i = i! - 1;
    }while(i);

    i = 5;
    do{
        Trace.print(i);
        i = null;
    }while(i);
}