fun main(){
    testNot();
}

fun testNot(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;

    Trace.print(not b)      // false
    Trace.print(not b2)     // true
    Trace.print(not b3)     // true

    var i as int? = 200;
    var n as int? = null;

    Trace.print(not i)         // false
    Trace.print(not n)         // true
}