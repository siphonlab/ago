fun main(){
    testAnd();
}

fun testAnd(){
    var b as boolean? = true;
    var b2 as boolean? = false;
    var b3 as boolean? = null;
    Trace.print(b and b2)       // false
    Trace.print(b3 and b)       // false
    Trace.print(b2 and b)       // false
    Trace.print(b3 and b3)      // false

    Trace.print(b and true)     // true
    Trace.print(true and b)     // true
    Trace.print(b2 and true)    // false
    Trace.print(true and b2)    // false
    Trace.print(b3 and true)    // false
    Trace.print(true and b3)    // false

    var i as int? = 200;
    var n as int? = null;

    Trace.print(i and n)        // null
    Trace.print(i and i)        // 200
    Trace.print(true and i)     // true, any side is boolean got boolean
    Trace.print(n and i)        // null
}