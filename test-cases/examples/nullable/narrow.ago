fun main(){
    var i as int? = 2026;
    var j = 2025;

    if(i != null){
        i++;                // here i is int
        Trace.print(i);
    }

    if(i != null and i > j){     // here i is int
        i++;
        Trace.print(i);     // 2007. i++ didn't involve the original nullable i
    }

    if(i == null){
        //
    } else {
        i += 2;         // 2028
        Trace.print(i);
    }

    var n as int? = 2027
    if(i == null or n == null){
        //
    } else {
        Trace.print(i + 1)  // 2027
        Trace.print(n + 1)  // 2028
    }


    if((i != null) == false){

    } else {
        Trace.print(i);     // 2026
    }
// TODO return shortcut
//    if(i == null) return;
//
//    i++;
//    Trace.print(i);

}