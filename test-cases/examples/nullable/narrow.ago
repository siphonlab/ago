fun main(){
    var i as int? = 2026;
    var j = 2025;

    if(i != null){
        i++;                // here i is int
        Trace.print(i);
    }

    if(i != null and i > j){     // here i is int
        i++;
        Trace.print(i);     // 2007. i++ didn't involve the original nullable i
    }

    if(i == null){
        //
    } else {
        i += 2;
        Trace.print(i);
    }

